# ════════════════════════════════════════════
# BharatDefence.site — Environment Variables
# Copy this file to .env and fill in values
# NEVER upload .env to GitHub
# ════════════════════════════════════════════

# REQUIRED — Get free at aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# OPTIONAL — Get free at unsplash.com/developers
UNSPLASH_KEY=your-unsplash-access-key

# OPTIONAL — Get free at newsapi.org (100 req/day)
NEWS_API_KEY=your-newsapi-key

# Your live domain
SITE_DOMAIN=https://bharatdefence.site
